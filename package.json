{
    "name": "browze-bot",
    "version": "1.0.0",
    "description": "Browze Bot — Automation Suite for Instagram, WhatsApp, Google Maps and Social Media",
    "main": "electron/main.js",
    "private": true,
    "scripts": {
        "start": "node sales/license-server/index.js",
        "install:all": "npm install --prefix server && npm install --prefix client",
        "start:server": "node server/index.js",
        "start:client": "npm run dev --prefix client",
        "dev": "concurrently --names \"SERVER,CLIENT\" --prefix-colors \"green,cyan\" \"npm run start:server\" \"npm run start:client\"",
        "build:client": "npm run build --prefix client",
        "electron:dev": "concurrently --names \"CLIENT,ELECTRON\" --prefix-colors \"cyan,yellow\" \"npm run start:client\" \"wait-on http://localhost:5173 && electron .\"",
        "rebuild:native": "electron-rebuild -f -w better-sqlite3 --module-dir server",
        "electron:build": "npm run rebuild:native && npm run build:client && electron-builder",
        "electron:build:win": "npm run rebuild:native && npm run build:client && electron-builder --win --x64",
        "release:patch": "npm version patch && git push && git push --tags",
        "release:minor": "npm version minor && git push && git push --tags",
        "release:major": "npm version major && git push && git push --tags"
    },
    "build": {
        "appId": "com.browzebot.app",
        "productName": "Browze Bot",
        "copyright": "Copyright © 2025 Browze Bot",
        "directories": {
            "output": "bin",
            "buildResources": "build"
        },
        "asar": true,
        "asarUnpack": [
            "server/**/*",
            "electron/**/*"
        ],
        "npmRebuild": false,
        "win": {
            "target": [
                {
                    "target": "nsis",
                    "arch": [
                        "x64"
                    ]
                }
            ],
            "icon": "build/icon.png"
        },
        "mac": {
            "target": "dmg",
            "category": "public.app-category.utilities",
            "icon": "build/icon.png"
        },
        "linux": {
            "target": [
                "AppImage",
                "deb"
            ],
            "icon": "build/icon.png"
        },
        "nsis": {
            "oneClick": false,
            "perMachine": false,
            "allowToChangeInstallationDirectory": true,
            "createDesktopShortcut": true,
            "createStartMenuShortcut": true,
            "deleteAppDataOnUninstall": false,
            "uninstallDisplayName": "Browze Bot"
        },
        "files": [
            "electron/**/*",
            "server/**/*",
            "client/dist/**/*",
            "!**/node_modules/.cache/**/*",
            "!**/node_modules/.bin/**/*",
            "!**/*.md",
            "!**/*.map",
            "!server/uploads/**/*",
            "!server/instagram/uploads/**/*",
            "!server/db/*.sqlite*",
            "!server/db/*.db*",
            "!server/.env*",
            "!server/clips/routes.js.bak*",
            "!server/cookies.json",
            "!server/.wwebjs_cache/**/*"
        ],
        "publish": {
            "provider": "github",
            "owner": "lucasfehari",
            "repo": "hero_leads",
            "releaseType": "release"
        }
    },
    "devDependencies": {
        "@electron/rebuild": "^3.7.1",
        "concurrently": "^9.1.2",
        "electron": "33.2.1",
        "electron-builder": "^25.1.8",
        "electron-updater": "^6.3.9",
        "wait-on": "^8.0.1"
    },
    "dependencies": {
        "localtunnel": "^2.0.2"
    }
}
