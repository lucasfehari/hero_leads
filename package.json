{
    "name": "browze-bot",
    "version": "1.0.0",
    "description": "Browze Bot — Automation Suite for Instagram, WhatsApp, Google Maps and Social Media",
    "main": "electron/main.js",
    "private": true,
    "scripts": {
        "install:all": "npm install --prefix server && npm install --prefix client",
        "start:server": "node server/index.js",
        "start:client": "npm run dev --prefix client",
        "dev": "concurrently --names \"SERVER,CLIENT\" --prefix-colors \"green,cyan\" \"npm run start:server\" \"npm run start:client\"",
        "build:client": "npm run build --prefix client",
        "electron:dev": "concurrently --names \"CLIENT,ELECTRON\" --prefix-colors \"cyan,yellow\" \"npm run start:client\" \"wait-on http://localhost:5173 && electron .\"",
        "electron:build": "npm run build:client && electron-builder"
    },
    "build": {
        "appId": "com.browzebot.app",
        "productName": "Browze Bot",
        "directories": {
            "output": "bin"
        },
        "win": {
            "target": "nsis"
        },
        "mac": {
            "target": "dmg",
            "category": "public.app-category.utilities"
        },
        "linux": {
            "target": ["AppImage", "deb"]
        },
        "nsis": {
            "oneClick": false,
            "allowToChangeInstallationDirectory": true,
            "createDesktopShortcut": true,
            "createStartMenuShortcut": true
        },
        "files": [
            "electron/**/*",
            "server/**/*",
            "client/dist/**/*",
            "!server/node_modules/**/*",
            "!**/node_modules/.cache/**/*"
        ],
        "extraResources": [
            { "from": "server/node_modules", "to": "server/node_modules" }
        ],
        "publish": {
            "provider": "github",
            "releaseType": "release"
        }
    },
    "devDependencies": {
        "concurrently": "^9.1.2",
        "electron": "^33.2.1",
        "electron-builder": "^25.1.8",
        "wait-on": "^8.0.1"
    },
    "dependencies": {
        "electron-updater": "^6.3.9",
        "localtunnel": "^2.0.2"
    }
}
