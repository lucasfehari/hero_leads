# Servidor de Licenças — Browze Bot v2.0
# Copie para .env e preencha com seus valores reais

# ─── Servidor ─────────────────────────────────────────────────────────────────
PORT=4444
ADMIN_TOKEN=troque-por-um-token-secreto-forte-aqui

# ─── Turso (SQLite gratuito) ───────────────────────────────────────────────────
# Crie grátis em: https://turso.tech
# Deixe em branco para usar arquivo local (desenvolvimento)
TURSO_URL=libsql://seu-banco.turso.io
TURSO_AUTH_TOKEN=seu-token-do-turso

# ─── Abacate Pay ──────────────────────────────────────────────────────────────
# Obtenha em: https://app.abacatepay.com → Configurações → Webhooks
ABACATEPAY_API_KEY=abc_dev_zM5qmj2rBdUeLR2SMZabqnwC
ABACATEPAY_WEBHOOK_SECRET=seu-webhook-secret-do-abacatepay

# ─── Email (para enviar chave ao comprador) ────────────────────────────────────
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=seu-email@gmail.com
SMTP_PASS=sua-senha-de-app-gmail

# ─── URL pública (após deploy no Railway) ─────────────────────────────────────
SERVER_URL=https://seu-app.railway.app
